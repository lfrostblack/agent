# ticket-backend configuration (values below are placeholders — do not commit real secrets)

# Async SQLAlchemy URL. In docker-compose this points at the `postgres` service;
# on Railway this is the managed Postgres DATABASE_URL (use the asyncpg driver).
DATABASE_URL=postgresql+asyncpg://tickets:tickets@postgres:5432/tickets

# Shared secret that protects write endpoints. MUST match TICKET_API_KEY on the
# agent-service side.
TICKET_API_KEY=change-me-shared-secret

LOG_LEVEL=INFO
