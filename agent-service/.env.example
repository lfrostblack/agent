# agent-service configuration (values below are placeholders — do not commit real secrets)

# ---- Required ----
ANTHROPIC_API_KEY=sk-ant-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ---- Model ----
# Support Q&A model. Configurable; defaults to Sonnet 5.
AGENT_MODEL=claude-sonnet-5
AGENT_MAX_TURNS=8

# ---- Warm per-thread session pool ----
# Max number of live warm sessions (each is a CLI subprocess). LRU-evicted above this.
SESSION_MAX=200
# Evict a session after this many seconds idle (no new message in the thread).
SESSION_IDLE_TTL=900
# Force-recycle a session this many seconds after creation. Keep this BELOW the
# Nominal token lifetime once Nominal is wired in, so every session gets a fresh
# token. (~50 min default.)
SESSION_MAX_AGE=3000
# How often the background sweeper checks for idle/aged sessions.
SESSION_SWEEP_INTERVAL=60

# ---- Behaviour ----
LOG_LEVEL=INFO
ACK_EMOJI=eyes
# PLACEHOLDER_TEXT=On it — looking into this…

